# ============================================================
# COP Engine — Environment Variables
# ============================================================
# Kopiera till .env och fyll i dina värden:
#   cp .env.example .env
# ============================================================

# === API ===
COP_ENV=production
COP_API_PORT=8000
COP_WORKERS=2
COP_LOG_LEVEL=info

# === Solver ===
COP_SOLVER_TIME_LIMIT=30
COP_SCHEDULE_WEEKS=2

# === COP MongoDB (persistent lagring) ===
# Om MongoDB inte är tillgänglig faller COP tillbaka till in-memory
COP_MONGO_URI=mongodb://cop-mongo:27017
COP_MONGO_DB=cop

# === Tessa / MongoDB ===
# Lämna tomt om du inte kopplar mot Tessa
TESSA_HOST=cop-mongo
TESSA_PORT=27017
TESSA_DATABASE=meteor
TESSA_DEPARTMENT=Ortopedi

# === LLM Agent (Claude) ===
# Hämta nyckel från https://console.anthropic.com
ANTHROPIC_API_KEY=

# === Nginx ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === MongoDB (extern port) ===
MONGO_PORT=27017
